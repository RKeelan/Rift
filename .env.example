# Server port (default: 13000)
PORT=13000

# Bind address (default: 127.0.0.1). Set to 0.0.0.0 to expose on all interfaces.
HOST=127.0.0.1

# Command to run for the agent process (default: echo)
AGENT_COMMAND=echo

# Root directory containing repositories. Required if it cannot be inferred
# from the current working directory (must contain a "src", "source", or
# "repos" segment under your home directory).
REPOS_ROOT=~/Src
